from django.urls import path
from django.contrib.auth import views as auth_views
from . import views

urlpatterns = [
    # 🔐 Auth
    path('accounts/login/', views.simple_login, name='login'),
    path('accounts/logout/', auth_views.LogoutView.as_view(next_page='login'), name='logout'),
    
    # 📊 Dashboard : accessible aux 2 URLs pour éviter tout problème
    path('', views.dashboard, name='dashboard'),
    path('dashboard/', views.dashboard, name='dashboard_alt'),
    
    # 📈 Bilan
    path('bilan/', views.bilan, name='bilan'),
    
    # ✍️ Formulaires
    path('production/add/', views.production_add, name='production_add'),
    path('vente/add/', views.vente_add, name='vente_add'),
    path('depense/add/', views.depense_add, name='depense_add'),
]
