from django.shortcuts import redirect
from django.contrib import admin
from django.urls import path
from django.contrib.auth import views as auth_views
from django.contrib.auth.decorators import login_required
from gestion import views

urlpatterns = [
    path('stock/sortie/', views.stock_sortie_add, name='stock_sortie'),
    path('stock/entree/', views.stock_entree_add, name='stock_entree'),
    path('stock/', views.stock_dashboard, name='stock_dashboard'),
    path('vente/', login_required(views.vente_choice), name='vente_choice'),
    path('vente/', lambda r: redirect('vente_oeufs'), name='vente'),

    path('', views.accueil, name='accueil'),
    path('dashboard/', login_required(views.dashboard), name='dashboard'),
    path('bilan/', login_required(views.bilan), name='bilan'),
    path('credits/', login_required(views.credits), name='credits'),
    # 🥚🐔📦 3 VENTES SÉPARÉES (comme demandé)
    path('vente/oeufs/', login_required(views.vente_oeufs), name='vente_oeufs'),
    path('vente/poules/', login_required(views.vente_poules), name='vente_poules'),
    path('vente/autres/', login_required(views.vente_autres), name='vente_autres'),
    # 📥 Autres saisies
    path('production/add/', login_required(views.production_add), name='production_add'),
    path('depense/add/', login_required(views.depense_add), name='depense_add'),
    path('sortie-poules/', login_required(views.sortie_poules_add), name='sortie_poules_add'),
    # 📤 Exports
    path('export/', login_required(views.export_excel), name='export_excel'),
    path('export/bilan/', login_required(views.export_bilan), name='export_bilan'),
    path('export/credits/', login_required(views.export_credits), name='export_credits'),
    # 🔐 Auth & Admin
    path('accounts/login/', auth_views.LoginView.as_view(template_name='gestion/login.html'), name='login'),
    path('accounts/logout/', auth_views.LogoutView.as_view(next_page='accueil'), name='logout'),
    path('admin/', admin.site.urls),
]
