from django import forms
from django.utils import timezone
from .models import ProductionOeufs, Vente, Depense, Poulailler

class ProductionForm(forms.ModelForm):
    # 📦 Champs virtuels pour double saisie (non stockés directement)
    nb_plateaux = forms.IntegerField(
        required=False, min_value=0,
        label="📦 Nombre de plateaux",
        widget=forms.NumberInput(attrs={'inputmode': 'numeric', 'placeholder': 'Ex: 10', 'class': 'form-control'})
    )
    oeufs_vrac = forms.IntegerField(
        required=False, min_value=0, max_value=29,
        label="🥚 Œufs en vrac (0-29)",
        widget=forms.NumberInput(attrs={'inputmode': 'numeric', 'placeholder': 'Ex: 15', 'class': 'form-control'})
    )
    total_oeufs_direct = forms.IntegerField(
        required=False, min_value=0,
        label="🔢 Total œufs direct",
        widget=forms.NumberInput(attrs={'inputmode': 'numeric', 'placeholder': 'Ex: 315', 'class': 'form-control'})
    )

    class Meta:
        model = ProductionOeufs
        fields = ['date', 'poulailler', 'nombre_oeufs', 'oeufs_casses']
        widgets = {
            'date': forms.DateInput(attrs={'type': 'date', 'class': 'form-control'}),
            'poulailler': forms.Select(attrs={'class': 'form-control'}),
            'nombre_oeufs': forms.HiddenInput(),  # Champ technique calculé
            'oeufs_casses': forms.NumberInput(attrs={'inputmode': 'numeric', 'class': 'form-control'})
        }

    def __init__(self, *args, **kwargs):
        super().__init__(*args, **kwargs)
        self.fields['nombre_oeufs'].required = False  # Désactive validation Django
        if not self.instance.pk:
            self.fields['date'].initial = timezone.now().date()
            self.fields['poulailler'].queryset = Poulailler.objects.all()
            self.fields['poulailler'].empty_label = "-- Sélectionner un bâtiment --"

    # ✅ clean() sera activé à l'étape 2 (pour l'instant, on laisse passer)
    # def clean(self):
    #     cleaned_data = super().clean()
    #     # ... logique de calcul ...
    #     return cleaned_data

class VenteForm(forms.ModelForm):
    class Meta:
        model = Vente
        fields = '__all__'
        widgets = {'date': forms.DateInput(attrs={'type': 'date', 'class': 'form-control'})}

class DepenseForm(forms.ModelForm):
    class Meta:
        model = Depense
        fields = '__all__'
        widgets = {'date': forms.DateInput(attrs={'type': 'date', 'class': 'form-control'})}
