                plateaux=0,
                unites=0,
                prix_plateau=0,
                montant_total=total,
                montant_paye=paye,
                mode_paiement=request.POST.get("mode_paiement") or "comptant",
                paye=(paye >= total)
            )
            messages.success(request, f"✅ Vente autres enregistrée : {total} FCFA")
