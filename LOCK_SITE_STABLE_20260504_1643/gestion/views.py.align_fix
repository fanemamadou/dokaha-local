        except Exception as e:
            messages.error(request, f"❌ Erreur : {e}")
    return render(request, "gestion/vente_autres.html", {"form": VenteForm()})

@login_required
def production_add(request):
    form = ProductionForm(request.POST) if request.method=="POST" else ProductionForm()
    if request.method=="POST" and form.is_valid(): form.save(); messages.success(request, "Collecte OK"); return redirect("dashboard")
    return render(request, "gestion/production_form.html", {"form": form})

